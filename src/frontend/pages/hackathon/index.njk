---
layout: base.template.njk
title: Welcome to bahn.dev
navigation: true
full_content: true
footer: true
---
{%- from "./../../templates/_setup/macros/component.macro.njk" import component -%}
<div class="container-fluid my-5">
    <div class="workspace-search">
        <label class="workspace-search__label" for="workspace-search-input">Workspace suchen</label>
        <div class="workspace-search__controls">
            <input
                id="workspace-search-input"
                class="workspace-search__input"
                type="search"
                placeholder="z. B. Hackraum 3, DAMPFLOK, SO 10 3.04 oder 6 Pax"
                autocomplete="off"
                data-search-input
            >
            <button class="workspace-search__clear" type="button" data-search-clear>Zurücksetzen</button>
        </div>

        <div class="workspace-filter-group" data-space-filter-group>
            <p class="workspace-filter-group__title">Spaces</p>
            <div class="workspace-filter-chips" data-space-filters></div>
        </div>

        <div class="workspace-filter-group" data-team-filter-group>
            <p class="workspace-filter-group__title">Teams</p>
            <div class="workspace-filter-chips" data-team-filters></div>
        </div>

        <p class="workspace-search__status" data-search-status>Workspaces werden geladen</p>
    </div>

    <div class="workspace-map text-center" data-search-scope style="font-size:0">
        {{
            component("svg", {
                path: "hackathon/MAP-FINAL.svg",
                size: "2000"
            })
        }}
    </div>
</div>

